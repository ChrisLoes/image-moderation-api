# ============================================
# API Configuration
# ============================================
API_KEYS=your-api-key-1,your-api-key-2
LOG_LEVEL=info

# ============================================
# Face Detection & Blurring
# ============================================
# Intensity level: low, medium, high
# - low: confidence=0.3, blur=11 (minimal detection & light blur)
# - medium: confidence=0.5, blur=25 (balanced)
# - high: confidence=0.8, blur=41 (aggressive detection & heavy blur)
FACE_DETECTION_INTENSITY=medium

# Optional: override individual parameters
FACE_DETECTION_CONFIDENCE=0.5
FACE_BLUR_STRENGTH=25

# ============================================
# NSFW Detection
# ============================================
# Intensity level: low, medium, high
# - low: threshold=0.8 (very lenient, only obvious NSFW)
# - medium: threshold=0.6 (balanced)
# - high: threshold=0.4 (aggressive, flags more content)
NSFW_DETECTION_INTENSITY=medium

# Optional: override threshold
NSFW_THRESHOLD=0.6

# ============================================
# Image Constraints
# ============================================
MAX_FILE_SIZE=8388608
MAX_IMAGE_WIDTH=4000
MAX_IMAGE_HEIGHT=4000

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
PORT=8000

# ============================================
# Docker Startup
# ============================================
# Set to 'false' to skip dependency installation on startup
INSTALL_DEPS=true
